# Supabase — connected to the existing AIWIZN project.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role key — used by /api/stripe/webhook only (server-side).
# Get from Supabase Dashboard → Project Settings → API → "service_role" key.
# DO NOT expose this client-side. Vercel project env only.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Site URL for OAuth / magic-link / Stripe redirect callbacks.
# Local: http://localhost:3000   Production: https://www.aiwizn.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Stripe (engines paywall) ===
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx

# From the webhook endpoint you create in Stripe Dashboard → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Individual plan prices on the "AIWIZN Engines Annual" Product.
# Annual recurring USD: $9.99 (early bird), $29.99 (regular).
STRIPE_PRICE_ID_EARLY_BIRD=price_xxx
STRIPE_PRICE_ID_REGULAR=price_xxx

# Institutional (per-nurse / per-seat) prices.
# Annual recurring USD: $279.99 (early bird), $349.99 (regular).
# Create on the SAME product as the individual prices, billed per_unit.
STRIPE_PRICE_ID_INSTITUTIONAL_EARLY_BIRD=price_xxx
STRIPE_PRICE_ID_INSTITUTIONAL_REGULAR=price_xxx

# Which tier the public /pricing page shows. Flip to "regular" when ready.
NEXT_PUBLIC_PRICING_TIER=early_bird
