# Supabase — create a project at https://supabase.com, then copy these from
# Project Settings → API. Set the same values in Vercel: Project → Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Site URL used by Supabase magic links / OAuth redirects.
# Local: http://localhost:3000
# Production: https://www.aiwizn.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
